{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "upstream-monitor",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-07",
  "routes": [
    {
      "pattern": "monitor.example.com/*",
      "zone_name": "example.com"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "MONITOR_DATA",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "triggers": {
    "crons": [
      "*/30 * * * *"
    ]
  }
}
